#!/usr/bin/env bash
# sdlc-check launcher. Resolves the checker relative to THIS script, so it works on PATH from any
# working directory — Claude Code adds a plugin's bin/ to the Bash PATH, so once agent-sdlc is
# installed a skill can call `sdlc-check <spec> …` with no path to the plugin (a cwd-relative
# `node agent-sdlc/checker/…` does NOT resolve in a user's own repo). The checker is a single
# zero-dependency ESM file, so plain `node` on the committed source runs it (no install-time build,
# no dependency — NC-3).
set -euo pipefail
# Resolve through symlinks so the launcher works whether the plugin adds bin/ to PATH or symlinks
# this script into a PATH dir, then locate the checker relative to the REAL script.
src="${BASH_SOURCE[0]:-$0}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
here="$(cd -P "$(dirname "$src")" && pwd)"
exec node "$here/../checker/sdlc-check.mjs" "$@"
